---
import Button from "./Button.astro";
---

<section class="px-6 md:px-20 pb-20">
    <div
        class="max-w-container mx-auto bg-background-light/80 dark:bg-background-dark/80 backdrop-blur-md border border-slate-200 dark:border-slate-800 rounded-3xl p-10 md:p-16 relative overflow-hidden flex flex-col items-center text-center gap-8 shadow-premium"
    >
        <div class="relative z-10 flex flex-col gap-8 max-w-[800px]">
            <h2
                class="text-slate-900 dark:text-slate-100 text-4xl md:text-5xl font-black leading-tight tracking-tight"
            >
                Kunjungi TikTok Kami Untuk Update Terbaru
            </h2>
            <div class="flex justify-center">
                <Button
                    variant="primary"
                    size="xl"
                    href="https://www.tiktok.com/@ebbygurih_"
                    class="w-full sm:w-auto"
                >
                    Ebby Gurih
                </Button>
            </div>
        </div>
    </div>
</section>
