<section class="px-6 md:px-20 pb-20 overflow-hidden">
    <div class="max-w-container mx-auto relative">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h2
                    class="text-slate-100 text-3xl font-bold tracking-tight mb-2"
                >
                    Koleksi Unggulan
                </h2>
                <div
                    class="h-1 w-20 bg-linear-to-r from-primary to-primary/40 rounded-full"
                >
                </div>
            </div>

            <div class="hidden md:flex gap-3">
                <button
                    id="prevBtn"
                    class="p-3 rounded-full border border-slate-800 hover:bg-slate-900 transition-colors flex items-center justify-center disabled:opacity-30 disabled:cursor-not-allowed group"
                    aria-label="Previous items"
                >
                    <span
                        class="material-symbols-outlined group-hover:-translate-x-1 transition-transform"
                        >arrow_back</span
                    >
                </button>
                <button
                    id="nextBtn"
                    class="p-3 rounded-full border border-slate-800 hover:bg-slate-900 transition-colors flex items-center justify-center disabled:opacity-30 disabled:cursor-not-allowed group"
                    aria-label="Next items"
                >
                    <span
                        class="material-symbols-outlined group-hover:translate-x-1 transition-transform"
                        >arrow_forward</span
                    >
                </button>
            </div>
        </div>

        <div
            id="collectionContainer"
            class="flex md:grid md:grid-cols-4 gap-6 overflow-x-auto pb-8 snap-x snap-mandatory scrollbar-hide no-scrollbar -mx-6 px-6 md:mx-0 md:px-0"
            style="touch-action: pan-x pan-y; overscroll-behavior-x: contain;"
        >
            <div
                class="min-w-[85vw] sm:min-w-[45vw] md:min-w-0 snap-center md:snap-align-none"
            >
                <div
                    class="group relative aspect-4/5 rounded-2xl overflow-hidden cursor-pointer shadow-lg hover:shadow-2xl transition-all duration-500"
                >
                    <img
                        alt="Full face helmet"
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                        src="/images/helm1.jpeg"
                    />
                    <div
                        class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-6 opacity-90 group-hover:opacity-100 transition-opacity"
                    >
                        <p
                            class="text-white text-xl font-bold hover-zoom-text mb-1"
                        >
                            Full Face Series
                        </p>
                        <p class="text-slate-300 text-sm">
                            Keamanan Tanpa Kompromi
                        </p>
                    </div>
                </div>
            </div>

            <div
                class="min-w-[85vw] sm:min-w-[45vw] md:min-w-0 snap-center md:snap-align-none"
            >
                <div
                    class="group relative aspect-4/5 rounded-2xl overflow-hidden cursor-pointer shadow-lg hover:shadow-2xl transition-all duration-500"
                >
                    <img
                        alt="Modular helmet"
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                        src="/images/helm2.jpeg"
                    />
                    <div
                        class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-6 opacity-90 group-hover:opacity-100 transition-opacity"
                    >
                        <p
                            class="text-white text-xl font-bold hover-zoom-text mb-1"
                        >
                            Modular Collection
                        </p>
                        <p class="text-slate-300 text-sm">
                            Fleksibilitas Maksimal
                        </p>
                    </div>
                </div>
            </div>

            <div
                class="min-w-[85vw] sm:min-w-[45vw] md:min-w-0 snap-center md:snap-align-none"
            >
                <div
                    class="group relative aspect-4/5 rounded-2xl overflow-hidden cursor-pointer shadow-lg hover:shadow-2xl transition-all duration-500"
                >
                    <img
                        alt="Classic helmet"
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                        src="/images/helm3.jpeg"
                    />
                    <div
                        class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-6 opacity-90 group-hover:opacity-100 transition-opacity"
                    >
                        <p
                            class="text-white text-xl font-bold hover-zoom-text mb-1"
                        >
                            Open Face Classic
                        </p>
                        <p class="text-slate-300 text-sm">
                            Gaya Retro Timeless
                        </p>
                    </div>
                </div>
            </div>

            <div
                class="min-w-[85vw] sm:min-w-[45vw] md:min-w-0 snap-center md:snap-align-none"
            >
                <div
                    class="group relative aspect-4/5 rounded-2xl overflow-hidden cursor-pointer shadow-lg hover:shadow-2xl transition-all duration-500"
                >
                    <img
                        alt="Off-road helmet"
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                        src="/images/helm4.jpeg"
                    />
                    <div
                        class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-6 opacity-90 group-hover:opacity-100 transition-opacity"
                    >
                        <p
                            class="text-white text-xl font-bold hover-zoom-text mb-1"
                        >
                            Off-Road Pro
                        </p>
                        <p class="text-slate-300 text-sm">
                            Siap Menjelajah Medan
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Scroll Indicator for mobile -->
        <div
            id="indicatorDots"
            class="flex justify-center gap-1.5 mt-2 md:hidden"
        >
            <div
                class="indicator-dot h-1.5 w-8 bg-primary rounded-full transition-all duration-300"
            >
            </div>
            <div
                class="indicator-dot h-1.5 w-1.5 bg-slate-800 rounded-full transition-all duration-300"
            >
            </div>
            <div
                class="indicator-dot h-1.5 w-1.5 bg-slate-800 rounded-full transition-all duration-300"
            >
            </div>
            <div
                class="indicator-dot h-1.5 w-1.5 bg-slate-800 rounded-full transition-all duration-300"
            >
            </div>
        </div>
    </div>
</section>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>

<script>
    const container = document.getElementById("collectionContainer");
    const prevBtn = document.getElementById("prevBtn");
    const nextBtn = document.getElementById("nextBtn");
    const dots = document.querySelectorAll("#indicatorDots .indicator-dot");

    if (container && prevBtn && nextBtn) {
        const updateUI = () => {
            const scrollLeft = container.scrollLeft;
            const maxScroll = container.scrollWidth - container.clientWidth;

            // Update buttons
            if (prevBtn instanceof HTMLButtonElement)
                prevBtn.disabled = scrollLeft <= 10;
            if (nextBtn instanceof HTMLButtonElement)
                nextBtn.disabled = scrollLeft >= maxScroll - 10;

            // Update dots
            if (dots.length > 0) {
                const itemWidth =
                    container.querySelector("div")?.clientWidth || 0;
                const index = Math.round(scrollLeft / (itemWidth + 24)); // 24 is gap-6

                dots.forEach((dot, i) => {
                    if (i === index) {
                        dot.classList.add("w-8", "bg-primary");
                        dot.classList.remove(
                            "w-1.5",
                            "bg-slate-300",
                            "dark:bg-slate-800",
                        );
                    } else {
                        dot.classList.remove("w-8", "bg-primary");
                        dot.classList.add("w-1.5", "bg-slate-800");
                    }
                });
            }
        };

        nextBtn.addEventListener("click", () => {
            container.scrollBy({ left: 300, behavior: "smooth" });
        });

        prevBtn.addEventListener("click", () => {
            container.scrollBy({ left: -300, behavior: "smooth" });
        });

        container.addEventListener("scroll", updateUI);
        window.addEventListener("resize", updateUI);
        updateUI();
    }
</script>
